# --- SaaS / безопасность ---
JWT_SECRET=change-me-in-production
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
# Публичный URL для Telegram setWebhook и return_url ЮKassa (в проде HTTPS)
PUBLIC_APP_URL=http://127.0.0.1:8080
# Редирект после оплаты ЮKassa: фронт показывает итог по query ?billing=… (success, cancel, fail)
# BILLING_SUCCESS_PATH=/?billing=success
# либо сразу в кабинет SPA: BILLING_SUCCESS_PATH=/workspace?billing=success

# Бонус кредитов при регистрации
SIGNUP_BONUS_CREDITS=50

# Админ-панель: API /api/admin и вкладка «Админ» (email владельца аккаунта, без parent). Через запятую.
# Альтернатива: в БД у владельца is_platform_admin=1. Bootstrap без правки БД:
# ADMIN_EMAILS=owner@example.com,ops@example.com

# Стоимость одного перевода (входящий / исходящий), если нет активной подписки
# CREDIT_COST_INBOUND_TRANSLATION=1
# CREDIT_COST_OUTBOUND_TRANSLATION=1

# --- ЮKassa (RUB): shop_id и секрет из личного кабинета; вебхук POST → /api/billing/yookassa/webhook ---
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
# Опционально: ?secret=… в URL вебхука или заголовок X-YooKassa-Webhook-Secret
# YOOKASSA_WEBHOOK_SECRET=
# WaveSpeed: для тарифа Managed студия использует платформенный ключ из .env; BYOK — ключ в кабинете «Интеграции».
# WAVESPEED_PLATFORM_API_KEY=
# Требовать активную подписку для студии (по умолчанию true; 402 без подписки). Для локальной отладки: false
# BILLING_REQUIRE_ACTIVE_SUBSCRIPTION=true
# BILLING_PRICE_MANAGED_MONTH_RUB=1299
# BILLING_MANAGED_SUBSCRIPTION_BONUS_CREDITS=250
# BILLING_PRICE_BYOK_MONTH_RUB=499
# BILLING_CREDIT_PACK_CREDITS=100
# BILLING_CREDIT_PACK_PRICE_RUB=990
# Покупка кредитов (произвольное количество; старый пакет выше — только для уже созданных платежей)
# BILLING_CREDITS_MIN_PURCHASE=50
# BILLING_CREDITS_BULK_FROM=200
# BILLING_CREDITS_UNIT_PRICE_RUB=3
# BILLING_CREDITS_BULK_UNIT_PRICE_RUB=2.70
# BILLING_CREDITS_MAX_PURCHASE=500000
# BILLING_SUBSCRIPTION_PERIOD_DAYS=30
# Пока ЮKassa не настроена (без shop_id + secret): новым и существующим владельцам автоматически
# выставляется активная подписка Managed — LLM студии через OPENAI_* с сервера; WaveSpeed — ключ из кабинета.
# После подключения ЮKassa режим сам отключается. Явно выключить: false
# BILLING_AUTO_STARTER_MANAGED_WITHOUT_PAYMENT=true

# PostgreSQL (Docker / прод)
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/chating

# --- Legacy: long polling одного бота на локального пользователя (user_id из БД) ---
# BOT_TOKEN=
# LEGACY_USER_ID=1

# TELEGRAM_PROXY=http://127.0.0.1:7890

# SQLite по умолчанию: backend/data/app.db
# DATABASE_URL=sqlite+aiosqlite:///...

# OpenAI — доработка промпта (вкладка «Генерация картинок»), ключ только на сервере
# OPENAI_API_KEY=
# Прокси с совместимым /v1 (по умолчанию https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1
# Несколько org в аккаунте — иногда требуется
# OPENAI_ORGANIZATION=org-...
# Модели (опционально; для OpenAI по умолчанию в коде — дешёвый текст + сильнее vision)
# OPENAI_STUDIO_MODEL=gpt-4o-mini
# OPENAI_STUDIO_MODEL_VISION=gpt-4o
#
# --- xAI Grok (тот же OpenAI-совместимый /v1; обычно дешевле флагмана) ---
# OPENAI_BASE_URL=https://api.x.ai/v1
# OPENAI_API_KEY=…           # из console.x.ai
# Текст: сбор JSON по шаблону — берите **mini / fast / non-reasoning** из pricing, не grok-4 «полный».
# Примеры идентификаторов смотрите в консоли: Models (они меняются; актуален «дешёвый» тир).
# OPENAI_STUDIO_MODEL=grok-3-mini
# Картинка-референс (шаг «описать фото»): нужна модель с **image input** — иначе оставьте пусто,
# тогда для обоих шагов возьмётся OPENAI_STUDIO_MODEL. Часто дешевле отдельная vision-модель:
# OPENAI_STUDIO_MODEL_VISION=grok-2-vision-1212
# (или одна и та же дешёвая модель, если в консоли у неё есть vision + text — проверьте вызовом)
# Стоимость в кредитах за один запрос «Собрать промпт»
# CREDIT_COST_STUDIO_PROMPT_REFINE=2
# Генерация JSON профиля модели по фото (кабинет → модели)
# CREDIT_COST_STUDIO_MODEL_PROFILE_GENERATE=1
# Апскейл сохранённой картинки студии (WaveSpeed Image Upscaler)
# CREDIT_COST_STUDIO_UPSCALE=1
# Разрешить в UI (vite dev) режим «только промпт» без WaveSpeed: POST … generate_wavespeed=0
# STUDIO_ALLOW_PROMPT_ONLY=true
# Шаблон JSON с <FILL> (в skeleton realism_engine: null — подставляется из файла ниже):
# IMAGE_STUDIO_SKELETON_PATH=data/prompts/image_studio_skeleton.txt
# IMAGE_STUDIO_SKELETON_INLINE=
# Системный промпт рефайнера (WAN; отдельно от скелета)
# (не оставляйте значение пустым — пусть строка отсутствует или путь к файлу; иначе раньше затирался default)
# IMAGE_STUDIO_SYSTEM_PATH=data/prompts/image_studio_system.txt
# IMAGE_STUDIO_SYSTEM_INLINE=
# Канонический блок realism_engine (подмешивается в шаблон и в ответ модели):
# IMAGE_STUDIO_REALISM_ENGINE_PATH=data/prompts/image_studio_realism_engine.json
# IMAGE_STUDIO_REALISM_ENGINE_INLINE=
# Текст шага 1 — описание референса (только поза/одежда/свет, без личности):
# IMAGE_STUDIO_REFERENCE_DESCRIBE_PATH=data/prompts/image_studio_reference_describe.txt
# IMAGE_STUDIO_REFERENCE_DESCRIBE_INLINE=
# Первый кадр референс-видео (вкладка «Видео»): детальная сцена без личности, игнор субтитров/лого
# MOTION_FIRST_FRAME_SCENE_DESCRIBE_PATH=data/prompts/motion_first_frame_scene_describe.txt
# MOTION_FIRST_FRAME_SCENE_DESCRIBE_INLINE=

# DeepL / LibreTranslate
# DEEPL_API_KEY=

# Стоимость одного кадра «Карусели» (Instagram-варианты по мастер-фото)
# CREDIT_COST_STUDIO_CAROUSEL_SHOT=2

# WaveSpeed (опционально, базовый URL API)
# WAVESPEED_API_BASE=https://api.wavespeed.ai
# Студия image-edit: по умолчанию WAN 2.7 (дешевле); Pro или Seedream — другой путь
# При WAN в интерфейсе можно переключать «Обычный» / «Pro»; при Seedream переключатель скрыт
# WAVESPEED_SEEDREAM_EDIT_PATH=/api/v3/alibaba/wan-2.7/image-edit
# WAVESPEED_SEEDREAM_EDIT_PATH=/api/v3/alibaba/wan-2.7/image-edit-pro
# WAVESPEED_SEEDREAM_EDIT_PATH=/api/v3/bytedance/seedream-v5.0-lite/edit
# WAVESPEED_SEEDREAM_EDIT_PATH=/api/v3/bytedance/seedream-v4.5/edit
# Image Upscaler (кнопка «Апскейл» в студии); sync — дождаться результата в POST
# WAVESPEED_IMAGE_UPSCALER_PATH=/api/v3/wavespeed-ai/image-upscaler
# WAVESPEED_UPSCALE_SYNC=true
# Сид для WAN 2.7 (-1 = случайный)
# WAVESPEED_WAN_IMAGE_EDIT_SEED=-1
# Размер для WAN в API: width*height (код сам меняет 1080x1920 → 1080*1920)
# Для v5 API: jpeg или png (опционально)
# WAVESPEED_SEEDREAM_OUTPUT_FORMAT=jpeg
# Seedream: true = результат в ответе POST (по умолчанию), false = асинхронно + poll
# WAVESPEED_SEEDREAM_SYNC=true
# true = не передавать size в API (как пустой размер в Playground; иначе уходит 1080x1920 и т.д. из кадра)
# WAVESPEED_SEEDREAM_OMIT_SIZE=false
# Доп. поля JSON-тела запроса (как в DevTools Playground). Если сервер отвечает обманчивым HTTP 200,
# попробуйте асинхронный режим: {"enable_sync_mode":false} (результат подождёт polling в коде).
# WAVESPEED_EXTRA_JSON=

# «Обычные фотографии» = Google Nano Banana Pro Edit (тот же wavespeed.ai, что и ключ в кабинете):
# https://wavespeed.ai/models/google/nano-banana-pro/edit  →  POST …/api/v3/google/nano-banana-pro/edit
# WAVESPEED_NANO_BANANA_PRO_EDIT_PATH=/api/v3/google/nano-banana-pro/edit
# WAVESPEED_NANO_BANANA_PRO_RESOLUTION=2k
# WAVESPEED_NANO_BANANA_PRO_SYNC=true
# WAVESPEED_NANO_BANANA_PRO_OUTPUT_FORMAT=png
# Шаг «Сделать видео» в студии: по умолчанию Kling v3.0 Pro Motion Control; WAN — через STUDIO_MOTION_VIDEO_PROVIDER=wan
# STUDIO_MOTION_VIDEO_PROVIDER=kling
# https://wavespeed.ai/docs (Kling Motion Control + driving video + image)
# WAVESPEED_KLING_MOTION_CONTROL_PATH=/api/v3/kwaivgi/kling-v3.0-pro/motion-control
# WAVESPEED_KLING_MOTION_SYNC=true
# Альтернатива: WAN 2.2 Animate — STUDIO_MOTION_VIDEO_PROVIDER=wan
# https://wavespeed.ai/docs/docs-api/wavespeed-ai/wan-2.2-animate
# WAVESPEED_WAN_22_ANIMATE_PATH=/api/v3/wavespeed-ai/wan-2.2/animate
# WAVESPEED_WAN_22_ANIMATE_MODE=replace
# WAVESPEED_WAN_22_ANIMATE_RESOLUTION=720p
# WAVESPEED_WAN_22_ANIMATE_SEED=-1
# Опционально: Seedance Fast Video-Edit Turbo (другие сценарии)
# WAVESPEED_STUDIO_VIDEO_EDIT_PATH=/api/v3/bytedance/seedance-2.0-fast/video-edit-turbo
# WAVESPEED_STUDIO_VIDEO_EDIT_RESOLUTION=720p
# CREDIT_COST_STUDIO_MOTION_CONTROL=10
# Лимит загрузки driving-video для /api/studio/motion/first-frame (МБ)
# STUDIO_MOTION_MAX_UPLOAD_MB=64
# Путь к ffmpeg: в Docker ставьте пакет в образ; при необходимости явно:
# FFMPEG_BINARY=/usr/bin/ffmpeg

# Web Push (VAPID): npx web-push generate-vapid-keys — публичный ключ на фронт, приватный только в .env
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# Контакт для подписи VAPID (mailto: или https:)
# VAPID_SUB=mailto:you@example.com

# CORS
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:8080

# Глобальный Fanvue (устарело для SaaS; токены задаются в личном кабинете)
# FANVUE_ACCESS_TOKEN=
# FANVUE_WEBHOOK_SECRET=

# Архив студии (локальные файлы): хранить N дней, затем фоновая очистка диска + БД.
# 0 — автоудаление отключено (файлы остаются, пока не удалит пользователь или админ).
# STUDIO_GENERATIONS_RETENTION_DAYS=4
# Интервал фоновой очистки (часы, минимум 1)
# STUDIO_GENERATIONS_RETENTION_INTERVAL_HOURS=24
