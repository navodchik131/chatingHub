# Обязательно для Telegram-бота (из @BotFather)
BOT_TOKEN=

# Если api.telegram.org не открывается (блокировка, таймаут): VPN или прокси
# Примеры: http://127.0.0.1:7890  или  socks5://127.0.0.1:1080
# Требуется: pip install aiohttp-socks (уже в requirements.txt)
# TELEGRAM_PROXY=

# Если порт 8000 на Windows даёт WinError 10013 — используйте другой, например 8080
# (и в frontend/.env задайте VITE_BACKEND_PORT=8080)
# BACKEND_PORT=8080

# SQLite: по умолчанию файл backend/data/app.db (абсолютный путь, не зависит от cwd)
# Можно переопределить:
# DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# DeepL Pro API (рекомендуется): https://www.deepl.com/pro-api
# Без ключа — fallback на публичный LibreTranslate (медленно/нестабильно)
DEEPL_API_KEY=
# DEEPL_USE_FREE=true

# Свой инстанс LibreTranslate (опционально)
# LIBRETRANSLATE_URL=https://libretranslate.com

# CORS для фронтенда Vite
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Fanvue (https://api.fanvue.com/docs) ---
# Секрет подписи вебхука: Developer Area → приложение → Webhooks → View Signing Secret
# FANVUE_WEBHOOK_SECRET=
# OAuth access token создателя с scope write:chat (и read:chat для вебхука входящих)
# FANVUE_ACCESS_TOKEN=
# FANVUE_API_VERSION=2025-06-26
# FANVUE_API_BASE=https://api.fanvue.com
