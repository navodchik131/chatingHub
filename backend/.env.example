# --- SaaS / безопасность ---
JWT_SECRET=change-me-in-production
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
# Публичный URL для Telegram setWebhook и return_url ЮKassa (в проде HTTPS)
PUBLIC_APP_URL=http://127.0.0.1:8080
# Редирект после оплаты ЮKassa: фронт показывает итог по query ?billing=… (success, cancel, fail)
# BILLING_SUCCESS_PATH=/?billing=success
# либо сразу в кабинет SPA: BILLING_SUCCESS_PATH=/workspace?billing=success

# Бонус кредитов при регистрации (0 для тарифа Credits — используйте DEMO_GENERATIONS_GRANT)
SIGNUP_BONUS_CREDITS=0
# Бесплатные генерации для новых пользователей на тарифе Credits
# DEMO_GENERATIONS_GRANT=3
# Реферальная программа (доп. кредиты при регистрации по коду + % рефереру с каждой оплаты друга)
REFERRAL_SIGNUP_BONUS_CREDITS=25
REFERRAL_REFERRER_PAYMENT_PERCENT=10
# 1 кредит = N ₽ (подписка кредитами, рефералка, докупка до bulk)
# BILLING_CREDITS_UNIT_PRICE_RUB=3.7
# Цифра на лендинге («N креаторов в бете»)
MARKETING_BETA_CREATORS_COUNT=19

# Админ-панель: API /api/admin и вкладка «Админ» (email владельца аккаунта, без parent). Через запятую.
# Альтернатива: в БД у владельца is_platform_admin=1. Bootstrap без правки БД:
# ADMIN_EMAILS=owner@example.com,ops@example.com

# --- Email / SMTP (рассылки из админки → вкладка «Рассылки») ---
# Свой Postfix на VPS: SMTP_HOST=127.0.0.1 SMTP_PORT=587 (relay через домен + SPF/DKIM обязательны)
# Yandex для домена: smtp.yandex.ru, порт 465 + SMTP_USE_SSL=true
# Reg.ru (почта на домене): mail.hosting.reg.ru
# Рекомендуем 587 + STARTTLS (465 часто блокируют с VPS):
# SMTP_HOST=mail.hosting.reg.ru
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_USER=support@model-mate.online
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=support@model-mate.online
# SMTP_FROM_NAME=ModelMate
# SMTP_TIMEOUT_SECONDS=15
# EMAIL_CAMPAIGN_BATCH_SIZE=25
# EMAIL_CAMPAIGN_BATCH_DELAY_SECONDS=2

# Стоимость одного перевода (входящий / исходящий), если нет активной подписки
# CREDIT_COST_INBOUND_TRANSLATION=1
# CREDIT_COST_OUTBOUND_TRANSLATION=1

# --- ЮKassa (RUB): shop_id и секрет из личного кабинета; вебхук POST → /api/billing/yookassa/webhook ---
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
# Опционально: ?secret=… в URL вебхука или заголовок X-YooKassa-Webhook-Secret
# YOOKASSA_WEBHOOK_SECRET=
# WaveSpeed: для тарифа Managed студия использует платформенный ключ из .env; BYOK — ключ в кабинете «Интеграции».
# WAVESPEED_PLATFORM_API_KEY=
# Требовать активную подписку для студии (по умолчанию true; 402 без подписки). Для локальной отладки: false
# BILLING_REQUIRE_ACTIVE_SUBSCRIPTION=true
# Тарифы подписок задаются в backend/app/services/plan_catalog.py (не в .env).
# Устаревшие переменные ниже не используются для новых оплат:
# BILLING_PRICE_MANAGED_MONTH_RUB=1299
# BILLING_MANAGED_SUBSCRIPTION_BONUS_CREDITS=250
# BILLING_PRICE_BYOK_MONTH_RUB=499
# BILLING_CREDIT_PACK_CREDITS=100
# BILLING_CREDIT_PACK_PRICE_RUB=990
# Покупка кредитов (произвольное количество; старый пакет выше — только для уже созданных платежей)
# BILLING_CREDITS_MIN_PURCHASE=50
# BILLING_CREDITS_BULK_FROM=200
# BILLING_CREDITS_UNIT_PRICE_RUB=3.7
# BILLING_CREDITS_BULK_UNIT_PRICE_RUB=2.70
# BILLING_CREDITS_MAX_PURCHASE=500000
# BILLING_SUBSCRIPTION_PERIOD_DAYS=30
# Пока ЮKassa не настроена (без shop_id + secret): новым и существующим владельцам автоматически
# выставляется активная подписка Managed — LLM студии через OPENAI_* с сервера; WaveSpeed — ключ из кабинета.
# После подключения ЮKassa режим сам отключается. Явно выключить: false
# BILLING_AUTO_STARTER_MANAGED_WITHOUT_PAYMENT=true

# PostgreSQL (Docker / прод)
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/chating

# --- Legacy: long polling одного бота на локального пользователя (user_id из БД) ---
# BOT_TOKEN=
# LEGACY_USER_ID=1

# TELEGRAM_PROXY=http://127.0.0.1:7890

# SQLite по умолчанию: backend/data/app.db
# DATABASE_URL=sqlite+aiosqlite:///...

# OpenAI — доработка промпта (вкладка «Генерация картинок»), ключ только на сервере
# OPENAI_API_KEY=
# Прокси с совместимым /v1 (по умолчанию https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1
# Несколько org в аккаунте — иногда требуется
# OPENAI_ORGANIZATION=org-...
# Модели (опционально; для OpenAI по умолчанию в коде — дешёвый текст + сильнее vision)
# OPENAI_STUDIO_MODEL=gpt-4o-mini
# OPENAI_STUDIO_MODEL_VISION=gpt-4o
#
# --- xAI Grok (тот же OpenAI-совместимый /v1; обычно дешевле флагмана) ---
# OPENAI_BASE_URL=https://api.x.ai/v1
# OPENAI_API_KEY=…           # из console.x.ai
# Текст: сбор JSON по шаблону — берите **mini / fast / non-reasoning** из pricing, не grok-4 «полный».
# Примеры идентификаторов смотрите в консоли: Models (они меняются; актуален «дешёвый» тир).
# OPENAI_STUDIO_MODEL=grok-3-mini
# Картинка-референс (шаг «описать фото»): нужна модель с **image input** — иначе оставьте пусто,
# тогда для обоих шагов возьмётся OPENAI_STUDIO_MODEL. Часто дешевле отдельная vision-модель:
# OPENAI_STUDIO_MODEL_VISION=grok-2-vision-1212
# (или одна и та же дешёвая модель, если в консоли у неё есть vision + text — проверьте вызовом)
# Стоимость в кредитах за один запрос «Собрать промпт»
# CREDIT_COST_STUDIO_PROMPT_REFINE=2
# Запрос с маской студии:
# По умолчанию (true) — полный кадр первым HTTPS-URL и маска тем же размером вторым URL в редакторе WAN/Nano; промпт задаёт области.
# При выборе модели её портреты добавляются дальше по правилам порядка в коде для Nano против WAN (см. studio_routes.py).
# false — Z-Image Turbo Inpaint (поле mask_image этого API).
# STUDIO_REGIONAL_MASKED_EDIT=true
# Переменные кроп-пайплайна ( PAD… / HARMONIZE… ): больше не используются при true, см. pydantic defaults в config если нужно чистое .env:
# STUDIO_REGIONAL_MASKED_EDIT_PAD_RATIO=0.14
# STUDIO_REGIONAL_MASKED_MIN_CROP_SIDE_PX=384
# STUDIO_REGIONAL_MASKED_FEATHER_RADIUS=5.5
# STUDIO_REGIONAL_MASKED_HARMONIZE_RING_THRESH=0.16
# STUDIO_REGIONAL_MASKED_MASK_THRESHOLD=100
# После WAN/Nano (полный кадр + маска вторым URL): смешать ответ провайдера с исходником —
# за пределами смягчённой маски пиксели как в загруженном фото (см. studio_masked_regional_edit.py).
# STUDIO_MASKED_FULLFRAME_PRESERVE_UNMASKED=true
# Радиус GaussianBlur альфы на стыке зон редактирования / исходника (меньше = жёстче шов).
# STUDIO_MASKED_FULLFRAME_BLEND_FEATHER_RADIUS=10
# CREDIT_COST_STUDIO_INPAINT=2
# Генерация JSON профиля модели по фото (кабинет → модели)
# CREDIT_COST_STUDIO_MODEL_PROFILE_GENERATE=1
# Апскейл сохранённой картинки студии (WaveSpeed Image Upscaler)
# CREDIT_COST_STUDIO_UPSCALE=1
# Разрешить в UI (vite dev) режим «только промпт» без WaveSpeed: POST … generate_wavespeed=0
# STUDIO_ALLOW_PROMPT_ONLY=true
# Шаблон JSON с <FILL> (в skeleton realism_engine: null — подставляется из файла ниже):
# IMAGE_STUDIO_SKELETON_PATH=data/prompts/image_studio_skeleton.txt
# IMAGE_STUDIO_SKELETON_INLINE=
# Системный промпт рефайнера (WAN; отдельно от скелета)
# (не оставляйте значение пустым — пусть строка отсутствует или путь к файлу; иначе раньше затирался default)
# IMAGE_STUDIO_SYSTEM_PATH=data/prompts/image_studio_system.txt
# IMAGE_STUDIO_SYSTEM_INLINE=
# Канонический блок realism_engine (подмешивается в шаблон и в ответ модели):
# IMAGE_STUDIO_REALISM_ENGINE_PATH=data/prompts/image_studio_realism_engine.json
# IMAGE_STUDIO_REALISM_ENGINE_INLINE=
# Текст шага 1 — описание референса (только поза/одежда/свет, без личности):
# IMAGE_STUDIO_REFERENCE_DESCRIBE_PATH=data/prompts/image_studio_reference_describe.txt
# IMAGE_STUDIO_REFERENCE_DESCRIBE_NO_FACE_PATH=data/prompts/image_studio_reference_describe_no_face.txt
# IMAGE_STUDIO_REFERENCE_DESCRIBE_INLINE=
# Первый кадр референс-видео (вкладка «Видео»): детальная сцена без личности, игнор субтитров/лого
# MOTION_FIRST_FRAME_SCENE_DESCRIBE_PATH=data/prompts/motion_first_frame_scene_describe.txt
# MOTION_FIRST_FRAME_SCENE_DESCRIBE_INLINE=

# DeepL / LibreTranslate
# DEEPL_API_KEY=

# Стоимость одного кадра «Карусели» (Instagram-варианты по мастер-фото)
# CREDIT_COST_STUDIO_CAROUSEL_SHOT=2

# WaveSpeed (опционально, базовый URL API)
# WAVESPEED_API_BASE=https://api.wavespeed.ai
# Студия image-edit: по умолчанию WAN 2.7 (дешевле); Pro или Seedream — другой путь
# При WAN в интерфейсе можно переключать «Обычный» / «Pro»; при Seedream переключатель скрыт
# WAVESPEED_SEEDREAM_EDIT_PATH=/api/v3/alibaba/wan-2.7/image-edit
# WAVESPEED_SEEDREAM_EDIT_PATH=/api/v3/alibaba/wan-2.7/image-edit-pro
# WAVESPEED_SEEDREAM_EDIT_PATH=/api/v3/bytedance/seedream-v5.0-lite/edit
# WAVESPEED_SEEDREAM_EDIT_PATH=/api/v3/bytedance/seedream-v4.5/edit
# Image Upscaler (кнопка «Апскейл» в студии); sync — дождаться результата в POST
# WAVESPEED_IMAGE_UPSCALER_PATH=/api/v3/wavespeed-ai/image-upscaler
# WAVESPEED_UPSCALE_SYNC=true
# Сид для WAN 2.7 (-1 = случайный)
# WAVESPEED_WAN_IMAGE_EDIT_SEED=-1
# Размер для WAN в API: width*height (код сам меняет 1080x1920 → 1080*1920)
# Для v5 API: jpeg или png (опционально)
# WAVESPEED_SEEDREAM_OUTPUT_FORMAT=jpeg
# Seedream: true = результат в ответе POST (по умолчанию), false = асинхронно + poll
# WAVESPEED_SEEDREAM_SYNC=true
# true = не передавать size в API (как пустой размер в Playground; иначе уходит 1080x1920 и т.д. из кадра)
# WAVESPEED_SEEDREAM_OMIT_SIZE=false
# Доп. поля JSON-тела запроса (как в DevTools Playground). Если сервер отвечает обманчивым HTTP 200,
# попробуйте асинхронный режим: {"enable_sync_mode":false} (результат подождёт polling в коде).
# WAVESPEED_EXTRA_JSON=

# «Обычные фотографии» = Google Nano Banana Pro Edit (тот же wavespeed.ai, что и ключ в кабинете):
# https://wavespeed.ai/models/google/nano-banana-pro/edit  →  POST …/api/v3/google/nano-banana-pro/edit
# WAVESPEED_NANO_BANANA_PRO_EDIT_PATH=/api/v3/google/nano-banana-pro/edit
# WAVESPEED_NANO_BANANA_PRO_RESOLUTION=2k
# WAVESPEED_NANO_BANANA_PRO_SYNC=false — async + poll (sync даёт 504 шлюза при долгой генерации)
# WAVESPEED_NANO_BANANA_PRO_SYNC=false
# WAVESPEED_NANO_BANANA_PRO_OUTPUT_FORMAT=png
# WAVESPEED_NANO_PROMPT_MAX_CHARS=12000
# Z-Image Turbo Inpaint (маска + референс; студия: поле «Маска inpaint»)
# WAVESPEED_Z_IMAGE_INPAINT_PATH=/api/v3/wavespeed-ai/z-image/turbo-inpaint
# true = не передавать size (размер как у входной картинки)
# WAVESPEED_Z_IMAGE_INPAINT_OMIT_SIZE=true
# Шаг «Сделать видео»: только Seedance 2.0 Text-to-Video (reference_images + @ImageN в промпте)
# https://wavespeed.ai/models/bytedance/seedance-2.0/text-to-video
# WAVESPEED_SEEDANCE_20_T2V_PATH=/api/v3/bytedance/seedance-2.0/text-to-video
# Swap по reference_videos (standard, не mini): Seedance 2.0 Fast T2V
# WAVESPEED_SEEDANCE_20_FAST_T2V_PATH=/api/v3/bytedance/seedance-2.0-fast/text-to-video
# Seedance 2.0 Mini T2V (легче/дешевле):
# WAVESPEED_SEEDANCE_20_MINI_T2V_PATH=/api/v3/bytedance/seedance-2.0-mini/text-to-video
# WAVESPEED_SEEDANCE_20_T2V_RESOLUTION=720p
# WAVESPEED_SEEDANCE_20_T2V_DURATION=5
# Длительность ролика в студии (сек): мин 4 (лимит WaveSpeed API), макс 15
# STUDIO_MOTION_VIDEO_DURATION_MIN=4
# STUDIO_MOTION_VIDEO_DURATION_MAX=15
# WAVESPEED_SEEDANCE_20_T2V_WEB_SEARCH=false
# Опрос Seedance на сервере (не в браузере): 800×3 с ≈ 40 мин
# WAVESPEED_VIDEO_MAX_POLLS=800
# WAVESPEED_VIDEO_POLL_INTERVAL_SECONDS=3
# Заглушки «processing» в архиве: через сколько ч помечать failed (долгие видео)
# STUDIO_GENERATION_STALE_PROCESSING_HOURS=48
# Видео Seedance T2V: кредиты = ceil(сек × USD/с × RUB/USD / RUB за кредит)
# С реф-видео $0.50/с → при 80 ₽/$ и 3.6 ₽/кредит ≈ 12 кр./с; без рефа $0.25/с ≈ 6 кр./с
# STUDIO_MOTION_USD_PER_SEC_WITH_REF=0.50
# STUDIO_MOTION_USD_PER_SEC_NO_REF=0.25
# Mini 720p (ориентир ~75% от Seedance 2.0 Fast; уточните после релиза Mini на WaveSpeed)
# STUDIO_MOTION_MINI_USD_PER_SEC_WITH_REF=0.0975
# STUDIO_MOTION_MINI_USD_PER_SEC_NO_REF=0.15
# STUDIO_MOTION_RUB_PER_USD=80
# STUDIO_MOTION_RUB_PER_CREDIT=3.6
# Устарело (игнорируется): CREDIT_COST_STUDIO_MOTION_CONTROL=10
# Лимит загрузки референс-видео для @Video1 (МБ)
# STUDIO_MOTION_MAX_UPLOAD_MB=64
# Путь к ffmpeg: в Docker ставьте пакет в образ; при необходимости явно:
# FFMPEG_BINARY=/usr/bin/ffmpeg
# exiftool для архива видео (phone Make/Model/GPS + снятие C2PA без перекодирования)
# EXIFTOOL_BINARY=/usr/bin/exiftool
# STUDIO_VIDEO_PHONE_EXPORT_ENABLED=true
# STUDIO_STRIP_AI_METADATA_ENABLED=true

# STUDIO_GROK_MOTION_TIMELINE=true
# По умолчанию выключено. При true и «Уточнить движение по ролику»: этапы xAI Grok:
# (1a) По умолчанию: ffmpeg ужимает клип до GROK_MOTION_MAX_SECONDS → загрузка в xAI Files → POST /v1/responses
# с GROK_MOTION_FULL_VIDEO_MODEL — анализ целого клипа во времени (мимика, движения).
# (1b) Если /files или /responses не срабатывает или GROK_MOTION_SEND_FULL_VIDEO=false → 1 Hz jpeg в /v1/chat/completions через GROK_MOTION_MODEL (нужны ffmpeg/ffprobe).
# (2) Текст из (1) + профиль + первый кадр (/v1/chat/completions vision) → итоговый промпт.
# GROK_API_KEY=
# GROK_BASE_URL=https://api.x.ai/v1
# GROK_MOTION_FULL_VIDEO_MODEL=grok-4
# Модель для jpeg-сэмплов и для шага 2. Пусто → OPENAI_STUDIO_MODEL_VISION, затем OPENAI_STUDIO_MODEL
# GROK_MOTION_MODEL=
# Отключить нативное видео и всегда только кадры: GROK_MOTION_SEND_FULL_VIDEO=false
# Без резерва jpeg при ошибке видеопути: GROK_MOTION_NATIVE_VIDEO_FALLBACK_FRAMES=false
# Макс размер mp4 перед Files API (байт): GROK_MOTION_XAI_UPLOAD_MAX_BYTES=47185920
# Таймаут /responses при разборе видео (сек): GROK_MOTION_FULL_VIDEO_TIMEOUT_SECONDS=900
# Если резерв jpeg: GROK_MOTION_MAX_SECONDS=30, GROK_MOTION_MAX_FRAME_WIDTH=768
#
# Студия «Grok: сцена» — ключ как у motion (OPENAI_API_KEY / GROK_API_KEY). Системный промпт:
# data/prompts/grok_scene_compose_system.txt — «Основная» (с референсом сцены).
# data/prompts/grok_scene_compose_text_system.txt — «По промту» (без референса).
# В Docker том скрывает data/prompts → читается _bundled_prompts/.
# GROK_SCENE_COMPOSE_SYSTEM_PATH=
# GROK_SCENE_COMPOSE_SYSTEM_INLINE=

# Web Push (VAPID): npx web-push generate-vapid-keys — публичный ключ на фронт, приватный только в .env
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# Контакт для подписи VAPID (mailto: или https:)
# VAPID_SUB=mailto:you@example.com

# CORS
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:8080

# Fanvue OAuth (приложение ChatingApp в Developer Area — один раз на сервер)
# FANVUE_CLIENT_ID=
# FANVUE_CLIENT_SECRET=
# Signing secret из Fanvue → Events → View Signing Secret
# FANVUE_WEBHOOK_SIGNING_SECRET=
# Redirect URI в Fanvue Authentication → Redirects (автоматически):
#   {PUBLIC_APP_URL}/api/integrations/fanvue/oauth/callback
# FANVUE_OAUTH_SCOPES=openid offline_access offline read:self read:chat write:chat
# Лимиты импорта истории (POST /api/integrations/fanvue/sync и фон после OAuth)
# FANVUE_SYNC_MAX_CHATS=100
# FANVUE_SYNC_MAX_MESSAGES_PER_CHAT=50
# Опрос inbox, если webhook Fanvue пропустил сообщение (сек; 0 = выкл.)
# FANVUE_INBOX_POLL_INTERVAL_SECONDS=45
# FANVUE_INBOX_POLL_MAX_CHATS=30
# FANVUE_INBOX_POLL_MAX_MESSAGES_PER_CHAT=12

# Устарело: глобальный токен / per-user ручной ввод
# FANVUE_ACCESS_TOKEN=
# FANVUE_WEBHOOK_SECRET=

# Архив студии (локальные файлы): хранить N дней, затем фоновая очистка диска + БД.
# 0 — автоудаление отключено (файлы остаются, пока не удалит пользователь или админ).
# STUDIO_GENERATIONS_RETENTION_DAYS=4
# Интервал фоновой очистки (часы, минимум 1)
# STUDIO_GENERATIONS_RETENTION_INTERVAL_HOURS=24

# Скачивание готового кадра с CDN провайдера в архив (повторы при обрыве или таймауте; также для «Сохранить в архив» по ссылке).
# STUDIO_ARCHIVE_DOWNLOAD_ATTEMPTS=6
# STUDIO_ARCHIVE_DOWNLOAD_TIMEOUT_SECONDS=300
# Перед phone EXIF: снять C2PA / «Made with AI» / AI EXIF с кадра (remove-ai-watermarks)
# STUDIO_STRIP_AI_METADATA_ENABLED=true
# Analog Humanizer: grain + хроматика против пиксельных AI-детекторов (CPU, remove-ai-watermarks)
# STUDIO_ANALOG_HUMANIZE_ENABLED=true
# STUDIO_ANALOG_HUMANIZE_GRAIN=2.5
# STUDIO_ANALOG_HUMANIZE_CHROMATIC_SHIFT=1
# Множитель grain_sigma в phone EXIF (после humanize grain не дублируется)
# STUDIO_PHONE_EXPORT_GRAIN_MULTIPLIER=1.15
# STUDIO_PHONE_EXPORT_JPEG_QUALITY=88
