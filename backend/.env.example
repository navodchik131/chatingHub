# --- SaaS / безопасность ---
JWT_SECRET=change-me-in-production
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
# Публичный URL для Telegram setWebhook и Stripe redirect (в проде HTTPS)
PUBLIC_APP_URL=http://127.0.0.1:8080

# Бонус кредитов при регистрации
SIGNUP_BONUS_CREDITS=50

# Стоимость одного перевода (входящий / исходящий), если нет активной подписки
# CREDIT_COST_INBOUND_TRANSLATION=1
# CREDIT_COST_OUTBOUND_TRANSLATION=1

# Stripe (опционально)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_SUBSCRIPTION=price_xxx

# PostgreSQL (Docker / прод)
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/chating

# --- Legacy: long polling одного бота на локального пользователя (user_id из БД) ---
# BOT_TOKEN=
# LEGACY_USER_ID=1

# TELEGRAM_PROXY=http://127.0.0.1:7890

# SQLite по умолчанию: backend/data/app.db
# DATABASE_URL=sqlite+aiosqlite:///...

# OpenAI — доработка промпта (вкладка «Генерация картинок»), ключ только на сервере
# OPENAI_API_KEY=
# Прокси с совместимым /v1 (по умолчанию https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1
# Несколько org в аккаунте — иногда требуется
# OPENAI_ORGANIZATION=org-...
# Модели (опционально)
# OPENAI_STUDIO_MODEL=gpt-4o-mini
# OPENAI_STUDIO_MODEL_VISION=gpt-4o
# Стоимость в кредитах за один запрос «Собрать промпт»
# CREDIT_COST_STUDIO_PROMPT_REFINE=2
# Шаблон в файле data/prompts/image_studio_skeleton.txt или одной строкой:
# IMAGE_STUDIO_SKELETON_INLINE=
# Текст первого запроса (описание референса для nano banana и т.д.):
# IMAGE_STUDIO_REFERENCE_DESCRIBE_PATH=data/prompts/image_studio_reference_describe.txt
# IMAGE_STUDIO_REFERENCE_DESCRIBE_INLINE=

# DeepL / LibreTranslate
# DEEPL_API_KEY=

# WaveSpeed (опционально, базовый URL API)
# WAVESPEED_API_BASE=https://api.wavespeed.ai
# Seedream: true = результат в ответе POST (по умолчанию), false = асинхронно + poll
# WAVESPEED_SEEDREAM_SYNC=true
# Доп. поля JSON-тела запроса (как в DevTools Playground). Если сервер отвечает обманчивым HTTP 200,
# попробуйте асинхронный режим: {"enable_sync_mode":false} (результат подождёт polling в коде).
# WAVESPEED_EXTRA_JSON=

# Web Push (VAPID): npx web-push generate-vapid-keys — публичный ключ на фронт, приватный только в .env
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# Контакт для подписи VAPID (mailto: или https:)
# VAPID_SUB=mailto:you@example.com

# CORS
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:8080

# Глобальный Fanvue (устарело для SaaS; токены задаются в личном кабинете)
# FANVUE_ACCESS_TOKEN=
# FANVUE_WEBHOOK_SECRET=
