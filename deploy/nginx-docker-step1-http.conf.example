# Шаг 1 — только HTTP, до выдачи сертификата.
# Замените chating.example.com на ваш домен.
# Скопируйте в /etc/nginx/sites-available/chatinghub, включите сайт, nginx -t, reload.
# Затем: certbot --nginx -d chating.example.com
# Certbot сам добавит HTTPS; при необходимости подправьте пути к fullchain/privkey под имя из /etc/letsencrypt/live/

upstream chatinghub_docker {
    server 127.0.0.1:8080;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name chating.example.com;
    client_max_body_size 25m;

    location /api/ws {
        proxy_pass http://chatinghub_docker;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400s;
    }

    location / {
        proxy_pass http://chatinghub_docker;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }
}
