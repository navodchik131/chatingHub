# Фрагмент для sites-enabled. Замените:
#   server_name, ssl_certificate, ssl_certificate_key
#   upstream порт — тот же, что у uvicorn (например 18080)
#
# Fanvue: POST /api/webhooks/fanvue и OAuth callback — БЕЗ auth_basic.

upstream chatinghub_backend {
    server 127.0.0.1:18080;
}

server {
    listen 443 ssl http2;
    server_name chating.example.com;

    ssl_certificate     /etc/letsencrypt/live/chating.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/chating.example.com/privkey.pem;

    location = /api/webhooks/fanvue {
        proxy_pass http://chatinghub_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    location = /api/integrations/fanvue/oauth/callback {
        proxy_pass http://chatinghub_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ~ ^/api/webhooks/fanvue/ {
        proxy_pass http://chatinghub_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    # WebSocket
    location /api/ws {
        proxy_pass http://chatinghub_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }

    location /api/studio/ {
        proxy_pass http://chatinghub_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    # Остальное — UI и API за паролем
    location / {
        auth_basic           "Chating Hub";
        auth_basic_user_file /etc/nginx/.htpasswd-chatinghub;

        proxy_pass http://chatinghub_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }
}
