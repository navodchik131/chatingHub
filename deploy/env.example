# Скопируйте в .env рядом с docker-compose или экспортируйте в shell.
# Обязательно задайте в продакшене: JWT_SECRET, FERNET_KEY, PUBLIC_APP_URL (HTTPS).

JWT_SECRET=replace-with-openssl-rand-hex-32
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Публичный URL приложения (для Telegram setWebhook и Stripe redirect)
PUBLIC_APP_URL=https://your-domain.com

# Stripe (опционально; без ключей эндпоинты биллинга вернут ошибку конфигурации)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SUBSCRIPTION=price_xxx

# Web Push (VAPID), npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUB=mailto:ops@your-domain.com

# CORS (через запятую)
CORS_ORIGINS=https://your-domain.com

# Бонус при регистрации
SIGNUP_BONUS_CREDITS=50

# WaveSpeed (студия): v5.0 Lite edit — см. backend/.env; sync / omit size
# WAVESPEED_SEEDREAM_EDIT_PATH=/api/v3/bytedance/seedream-v5.0-lite/edit
# WAVESPEED_SEEDREAM_SYNC=true
# WAVESPEED_SEEDREAM_OMIT_SIZE=true

# OpenAI — студия / сборка JSON промпта (в docker-compose прокидывается в сервис api)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_ORGANIZATION=

# PostgreSQL (переопределение для docker-compose обычно не нужно)
# DATABASE_URL=postgresql+asyncpg://chating:chating@db:5432/chating
