{
  "name": "modelmate-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.site.config.js",
    "dev:site": "vite --config vite.site.config.js",
    "dev:workflow": "vite --config vite.site.config.js",
    "build": "vite build --config vite.site.config.js && vite build --config vite.workflow.config.js",
    "build:site": "vite build --config vite.site.config.js",
    "build:workflow": "vite build --config vite.workflow.config.js",
    "preview": "vite preview --config vite.site.config.js --port 5173 --strictPort",
    "sync-design": "node scripts/sync-design.mjs"
  },
  "dependencies": {
    "@xyflow/react": "^12.11.1",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.9.3",
    "vite": "^6.3.5"
  }
}
