{
  "expo": {
    "name": "ModelMate",
    "slug": "modelmate",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/logo-m.jpeg",
    "scheme": "modelmate",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.modelmate.mobile"
    },
    "android": {
      "package": "app.modelmate.mobile",
      "versionCode": 3,
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": true,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#0A0B0D",
        "foregroundImage": "./assets/logo-m.jpeg"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/logo-m.jpeg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo-m.jpeg",
          "resizeMode": "contain",
          "backgroundColor": "#0A0B0D"
        }
      ],
      "expo-local-authentication",
      "expo-image",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo-m.jpeg",
          "color": "#D7F452",
          "defaultChannel": "messages"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "ModelMate сохраняет сгенерированные фото и видео в галерею.",
          "savePhotosPermission": "ModelMate сохраняет сгенерированные фото и видео в галерею.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "caddfb30-23d5-405d-90d2-c326ce37aca3"
      }
    }
  }
}
